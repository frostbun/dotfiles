[user]
    email = manhnb1911@gmail.com
    name = Manh Nguyen
[commit]
    gpgsign = true
[tag]
    gpgSign = true
[push]
    autoSetupRemote = true
    followTags = true
[pull]
    ff = only
[alias]
    yike = "!git submodule foreach --quiet pwd | parallel 'echo -ne \"\\e[32m$(basename {})\\e[0m - \" && git -C {} fetch -p --quiet && git -C {} pull --quiet && git -C {} log -1 --color=always --format=\"%Cred%h%Creset - %s\"'"
    release = "!f() { git tag -a \"v$1\" -m \"$1\"; }; f"
    lazy = "!lazygit"
    fr = "!git fetch && git stash save && git rebase && git stash pop"
    frp = "!git fetch && git stash save && git rebase && git push && git stash pop"
[core]
    editor = vim
    autocrlf = input
[init]
    defaultBranch = master
[advice]
    diverging = false
    detachedHead = false
    addEmbeddedRepo = false
    addEmptyPathspec = false
    skippedCherryPicks = false
    addIgnoredFile = false
	forceDeleteBranch = false
[credential]
    helper = /usr/lib/git-core/git-credential-libsecret
